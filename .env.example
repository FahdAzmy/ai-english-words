# MongoDB Configuration
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.example.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=vocabmaster
DEFAULT_USER_ID=user_1
DEFAULT_USER_EMAIL=learner@example.com

# LLM Provider Configuration
# Supported values: mock | openai | gemini | openrouter
LLM_PROVIDER=openrouter

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional but recommended by OpenRouter
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=VocabMaster

